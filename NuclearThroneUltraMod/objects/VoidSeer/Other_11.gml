var al = array_length(textQueue);
for (var i = 0; i < al; i ++)
{
	if string_letters(textQueue[i]) == ""
		textQueue[i] = 0;
	else
		textQueue[i] = string_letters(textQueue[i]);
}*/
textQueue[array_length(textQueue)] = "";
dialogueStep = 0;
with TextHandler
{
	text = other.textQueue[other.dialogueStep];
}
alarm[2] = 5;