draw_self();

if drawCancel
{
	draw_text_colour(x+1,y-48,"[E] TO CANCEL",c_black,c_black,c_black,c_black,1);
	draw_text_colour(x+1,y-47,"[E] TO CANCEL",c_black,c_black,c_black,c_black,1);
	draw_text_colour(x,y-47,"[E] TO CANCEL",c_black,c_black,c_black,c_black,1);
	draw_text_colour(x,y-48,"[E] TO CANCEL",c_white,c_white,c_white,c_white,1);
}