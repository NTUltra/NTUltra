function scrDecideUltraWep() {
	var wep = 0;
	var w = 0;
	var ls = GetPlayerLoops();
	if scrIsGamemode(31)
	{
		//Melee only
		if ls > 1
		{
			return choose(118,301,369,431,478,507,693,846,850,864,877,900);
		}
		else
		{
			return choose(118,301,369,431,478,507,693,864,877,900);
		}
	}
	var maxTries = 1000;
	if instance_exists(Player) && Player.race = 8
		maxTries = 2000;
	do 
	{
		if ls > 1
		{
			w = choose(114,115,116,117,118,120,121,192,193,199,248,289,297,299,301,302,303,304,341,369,371,427,431,434,435,468,472,473,478,487,494,503,504,506,507,510,513,524,530,568,582,602,618,631,642,650,675,688,689,690,691,692,693,725,764,768,801,807,838,839,841,846,847,848,849,850,864,877,878,879,880,888,900,902)
		}
		else
		{
			w = choose(114,115,116,117,118,120,121,192,193,199,248,289,297,299,301,302,304,341,369,371,427,431,434,435,468,472,473,478,487,494,503,504,506,507,510,513,524,530,568,602,618,631,642,650,675,688,689,690,691,692,693,725,764,768,801,807,838,841,849,864,877,880,888,900)
		}
		maxTries --;
	}
	until ((!instance_exists(Player) || maxTries <= 0 ||
	((w != Player.wep and w != Player.bwep) or Player.race = 7))
	)
	return w;
}
