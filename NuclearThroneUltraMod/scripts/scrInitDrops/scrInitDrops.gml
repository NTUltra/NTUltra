function scrInitDrops(amountOfDrops){
	itemDropChance = [];
	itemDropChanceIndex = -1;
	weaponDropChance = [];
	weaponDropChanceIndex = -1;
	confDropChance = [];
	confDropChanceIndex = -1;
	
	
	//Default 1, flexible elbows 3, heavy heart 1
	scrAddDrops(amountOfDrops);
}