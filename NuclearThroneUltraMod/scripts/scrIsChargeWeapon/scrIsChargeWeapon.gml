function scrIsChargeWeapon(inputWep){
	return inputWep == 680 || inputWep == 294 || inputWep == 295 || inputWep == 296 || inputWep == 314 || inputWep == 685
	|| inputWep == 502 || inputWep == 503 || inputWep == 567 || inputWep == 576 || inputWep == 680 || inputWep == 740
	|| inputWep == 785
}